{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "enabledManagers": [
    "github-actions",
    "nix"
  ],
  "nix": {
    "enabled": true
  },
  "ignorePaths": [
    "/results/**"
  ],
  "packageRules": [
    {
      "description": "Auto-merge GitHub actions minor updates",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    }
  ]
}
